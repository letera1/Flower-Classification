# Flower Classification API - Environment Configuration
# =====================================================
# Copy this file to .env and update values as needed

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# App Info
APP_NAME="Flower Classification API"
APP_VERSION="1.0.0"

# Logging
LOG_LEVEL=INFO

# Model Paths (optional - defaults to backend/models/artifacts)
# MODEL_PATH=
# PREPROCESSOR_PATH=

# Data Settings
TEST_SIZE=0.2
RANDOM_STATE=42
